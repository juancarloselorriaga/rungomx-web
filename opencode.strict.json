{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "default_agent": "orchestrator",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "instructions": ["AGENTS.md", "prompts/standards/**/*.md", "prompts/auth-stack/**/*.md"],
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["npx", "next-devtools-mcp@latest"],
      "enabled": false
    },
    "codex": {
      "type": "local",
      "command": ["npx", "-y", "codex", "mcp-server"],
      "enabled": false
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "/Users/juancarloselorriaga/Developer/proyectos-clientes/rungomx/rungomx-web"
      ],
      "enabled": false
    },
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.chonkie.ai/better-auth/better-auth-builder/mcp",
      "enabled": false
    }
  },
  "watcher": {
    "ignore": ["node_modules", ".next", ".next-e2e", "dist", "coverage"]
  }
}
